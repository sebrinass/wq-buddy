{
  "name": "wq-buddy",
  "version": "1.6.0",
  "description": "WQBuddy - WorldQuant BRAIN Alpha挖掘AI协作工具",
  "type": "module",
  "main": "dist/tools.js",
  "bin": {
    "wq": "./dist/cli-wrapper.js",
    "wq-buddy": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/tools.js",
    "./cli": "./dist/cli.js",
    "./wrapper": "./dist/cli-wrapper.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli-wrapper.ts",
    "start": "node dist/cli-wrapper.js",
    "wq": "tsx src/cli-wrapper.ts",
    "docs": "tsx src/cli-wrapper.ts docs",
    "search": "tsx src/cli-wrapper.ts search",
    "db": "tsx src/db-cli.ts",
    "watch": "tsc --watch",
    "link": "npm link"
  },
  "keywords": [
    "worldquant",
    "alpha",
    "brain",
    "quant",
    "openclaw",
    "openclaw-plugin"
  ],
  "files": [
    "dist/",
    "references/",
    "skill/",
    "config.example.json",
    "openclaw.plugin.json",
    "README.md"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/plugin-entry.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.1",
      "minGatewayVersion": "2026.3.1"
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "@types/better-sqlite3": "^7.6.13",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.9.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "csv-writer": "^1.6.0",
    "drizzle-orm": "^0.45.2",
    "inquirer": "^8.2.6"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.10.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  }
}
